# LLM Providers
# =============
# Ollama runs locally via Docker (see ../llm docker containers/). No API key needed.
OLLAMA_BASE_URL=http://localhost:11434

# Google Gemini — free tier available at https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Anthropic Claude — paid, https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here


# Agent defaults
# ==============
DEFAULT_PROVIDER=ollama
DEFAULT_MODEL=llama3.2:3b


# Database (RAG storage)
# ======================
# Postgres+pgvector is the shared ../llm docker containers/ stack (port 5432, db/user skillab).
DATABASE_URL=postgresql://skillab:skillab_dev@localhost:5432/skillab


# Observability (optional)
# ========================
# LangSmith — traces every LLM call + tool execution at https://smith.langchain.com
# Leave LANGCHAIN_TRACING_V2 unset (or =false) to disable.
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=lsv2_pt_your_langsmith_key_here
LANGCHAIN_PROJECT=skillab-ai-engineer
# This repo's LangSmith account is in the EU region.
# Use https://api.smith.langchain.com instead if your account is in the US.
LANGCHAIN_ENDPOINT=https://eu.api.smith.langchain.com